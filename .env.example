# Map tiles - sign up at https://maptiler.com (free tier: 100k tiles/month)
VITE_MAPTILER_API_KEY=

# Mapillary client token - https://www.mapillary.com/dashboard/developers (free)
VITE_MAPILLARY_CLIENT_TOKEN=

# Optional: OSM Nominatim mirror (default uses public instance)
VITE_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Optional: Overpass mirror (default uses public instance)
VITE_OVERPASS_URL=https://overpass-api.de/api/interpreter

# DGT (Portugal) WMS for high-res orthophotos
VITE_DGT_WMS_URL=https://cartografia.dgterritorio.gov.pt/wms/ortos2018

# Default map center (Lisboa)
VITE_DEFAULT_CENTER_LON=-9.1393
VITE_DEFAULT_CENTER_LAT=38.7223
VITE_DEFAULT_ZOOM=12
