{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PYE Prospector",
  "version": "0.1.0",
  "identifier": "io.fialho.pyeprospector",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PYE Prospector",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost https:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2QUFDOEUxNDRFOTIxOUEKUldTYUllbEU0Y2lxRnNaNzdrS0tUekJWclRwZ096K2NSVHNQdzBpL3hMcnV5a2hGYWY0Z0hzdjYK",
      "endpoints": [
        "https://github.com/LuisPCFialho/pye-prospector/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Solar C&I rooftop prospecting",
    "longDescription": "Identify commercial and industrial rooftops with and without solar panels. Plan, prospect, and manage solar opportunities on a map."
  }
}
