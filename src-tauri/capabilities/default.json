{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for PYE Prospector",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "dialog:default",
    {
      "identifier": "sql:default",
      "allow": [
        {
          "database": "sqlite:pye_prospector.db"
        }
      ]
    },
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close",
    "updater:default",
    "process:default"
  ]
}
